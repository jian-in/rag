# ============================================================
# RAG 知识库系统 - 环境变量配置
# ============================================================
# 复制此文件为 .env 并填入你的 API Key
# cp .env.example .env

# [必填] OpenAI API Key（或兼容接口的 Key）
OPENAI_API_KEY=sk-your-api-key-here

# [可选] 自定义 API 端点（用于本地模型或代理服务）
# OPENAI_API_BASE=https://your-custom-endpoint/v1

# [可选] LLM 模型名称，默认 gpt-4o-mini
# LLM_MODEL_NAME=gpt-4o-mini

# [可选] LLM 温度参数，RAG 场景建议 0
# LLM_TEMPERATURE=0

# [可选] Embedding 模型名称
# [???? Embedding ???????????SiliconFlow + BAAI/bge-m3??
# SILICONFLOW_API_KEY=your-siliconflow-key-here
# EMBEDDING_MODEL_NAME=BAAI/bge-m3
# EMBEDDING_API_BASE=https://api.siliconflow.cn/v1
# EMBEDDING_API_KEY=your-siliconflow-key-here
# EMBEDDING_DIMENSION=1024

# [可选] 分块参数
# CHUNK_SIZE=1000
# CHUNK_OVERLAP=200

# [可选] 检索参数
# RETRIEVAL_TOP_K=5
# MMR_LAMBDA=0.6

# [可选] 重排序（需要 Cohere API Key）
# [??] ???????? SiliconFlow + BAAI/bge-reranker-v2-m3?
# ENABLE_RERANKER=false
# RERANKER_MODEL=BAAI/bge-reranker-v2-m3
# RERANKER_PROVIDER=siliconflow
# RERANKER_MAX_CHUNKS_PER_DOC=1024
# RERANKER_OVERLAP_TOKENS=60
# [??] Cohere ????
# COHERE_API_KEY=your-cohere-key-here
# RERANKER_TOP_N=3
